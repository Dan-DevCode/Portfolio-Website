# Server-side only — never expose to the client (no VITE_ prefix).
GITHUB_USERNAME=dsamarin-ai
GITHUB_CONTRIBUTIONS_API_URL=https://github-contributions-api.jogruber.de/v4

# Rate limiting (per IP, per serverless instance)
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000

# Future authentication (HTTP-only secure cookies)
# SESSION_SECRET=generate-a-long-random-string-here
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=strict
